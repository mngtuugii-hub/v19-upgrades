<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_clear_package" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.clear.package</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_clear_destination_packages" 
                        string="Clear Dest. Packages" 
                        type="object" 
                        class="btn-secondary"
                        invisible="state == 'done'"/>
            </xpath>

        </field>
    </record>
</odoo>