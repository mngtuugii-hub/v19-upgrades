<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_tug_separate_packs" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.tug.separate.packs</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Add button next to the standard 'Put in Pack' button -->
            <!-- We use 'action_put_in_pack' as the anchor point -->
            <xpath expr="//button[@name='action_put_in_pack']" position="after">
                <button name="action_put_in_separate_packs" 
                        string="Put in Separate Packs" 
                        type="object" 
                        class="btn btn-secondary"
                        groups="stock.group_tracking_lot"
                        invisible="state not in ('assigned', 'processing')"/>
            </xpath>
        </field>
    </record>
</odoo>