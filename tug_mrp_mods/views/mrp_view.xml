<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_inherit_report" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.report</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <div class="alert alert-info text-center mt-2 mb-2" 
                     groups="mrp.group_mrp_user"
                     role="alert">
                    
                    <!-- Internal Report Button -->
                    <button name="%(action_report_mrp_internal)d" 
                            string="Print Internal Report" 
                            type="action" 
                            class="btn btn-primary me-2"
                            invisible="state == 'done'"/>

                    <!-- NEW: Update from BoM Button -->
                    <!-- Visible in Draft and Confirmed, Hidden in Done/Cancel -->
                    <button name="action_update_from_bom" 
                            string="Update from BoM" 
                            type="object" 
                            class="btn btn-warning me-2"
                            confirm="This will reset the component lines to match the current BoM. Continue?"
                            invisible="state in ('done', 'cancel')"/>
                    
                    <!-- External Report Button -->
                    <button name="%(action_report_mrp_external)d" 
                            string="Print External Report" 
                            type="action" 
                            class="btn btn-secondary"
                            invisible="state != 'done'"/>
                    
                    <!-- Report Options Wizard -->
                    <button name="%(action_mrp_report_wizard)d" 
                            string="Report Options" 
                            type="action" 
                            class="btn btn-secondary ms-2"
                            invisible="state != 'done'"/>
                            
                </div>
            </xpath>
        </field>
    </record>
</odoo>