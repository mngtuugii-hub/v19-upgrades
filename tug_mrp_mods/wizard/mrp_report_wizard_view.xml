<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_report_wizard_form" model="ir.ui.view">
        <field name="name">mrp.report.wizard.form</field>
        <field name="model">mrp.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Report Options">
                <sheet>
                    <div class="text-center mb-4 text-muted">
                        <h3>Select an Action</h3>
                    </div>
                    
                    <!-- Tablet Friendly Layout: Large Buttons -->
                    <div class="row g-3">
                        <div class="col-12 mb-3">
                            <button name="action_print_direct" string="🖨️ Print Report" type="object" class="btn btn-primary w-100 p-4" style="font-size: 1.5rem; border-radius: 10px;"/>
                        </div>
                        <div class="col-12 mb-3">
                            <button name="action_download_direct" string="⬇️ Download PDF" type="object" class="btn btn-secondary w-100 p-4" style="font-size: 1.5rem; border-radius: 10px;"/>
                        </div>
                        <div class="col-12 mb-3">
                            <button name="action_label_direct" string="🏷️ Print ZPL Labels" type="object" class="btn btn-warning w-100 p-4" style="font-size: 1.5rem; border-radius: 10px;"/>
                        </div>
                        <div class="col-12">
                            <button name="action_email_direct" string="📧 Email Customer" type="object" class="btn btn-success w-100 p-4" style="font-size: 1.5rem; border-radius: 10px;"/>
                        </div>
                    </div>
                    
                    <field name="action_type" invisible="1"/>
                    <field name="production_id" invisible="1"/>
                </sheet>
                <footer>
                    <button string="Cancel" class="btn-link" special="cancel" style="font-size: 1.2rem;"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mrp_report_wizard" model="ir.actions.act_window">
        <field name="name">Report Options</field>
        <field name="res_model">mrp.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_production_id': active_id}</field>
    </record>
</odoo>
