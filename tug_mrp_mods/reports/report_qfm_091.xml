<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_qfm_091" model="ir.actions.report">
        <field name="name">QFM-091 - Blend: Start-Shut</field>
        <field name="model">mrp.production</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tug_mrp_mods.report_qfm_091_template</field>
        <field name="report_file">tug_mrp_mods.report_qfm_091_template</field>
        <field name="paperformat_id" ref="paperformat_portrait_label_75dpi"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_qfm_091_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="main_lot" t-value="o.lot_producing_ids[0] if o.lot_producing_ids else False"/>

                <t t-call="web.internal_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 12px; color: #000;">
                        <!-- Main Container Border -->
                        <div style="border: 2px solid #000;">
                            
                            <!-- 1. Document Header -->
                            <div class="row m-0" style="border-bottom: 2px solid #000;">
                                <div class="col-3 p-2 d-flex align-items-center justify-content-center" style="border-right: 1px solid #000;">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 50px; max-width: 100%;"/>
                                    <span t-else="" t-field="o.company_id.name" style="font-weight: bold; font-size: 14px;"/>
                                </div>
                                <div class="col-6 p-2 text-center d-flex flex-column justify-content-center" style="border-right: 1px solid #000;">
                                    <h4 style="margin: 0; font-weight: 900; text-transform: uppercase;">Blending: Start-Shut Checklist</h4>
                                </div>
                                <div class="col-3 p-1" style="font-size: 10px;">
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Doc No:</strong></div>
                                        <div class="col-8">QFM-091</div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Rev:</strong></div>
                                        <div class="col-8">1.0</div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Page:</strong></div>
                                        <div class="col-8"><span class="page"/> of <span class="topage"/></div>
                                    </div>
                                </div>
                            </div>

                            <!-- 2. Order Information -->
                            <div class="row m-0" style="background-color: #f0f0f0; border-bottom: 1px solid #000;">
                                <div class="col-12 p-1 pl-2"><strong>ORDER DETAILS</strong></div>
                            </div>
                            <div class="row m-0" style="border-bottom: 2px solid #000;">
                                <div class="col-6 p-0" style="border-right: 1px solid #000;">
                                    <div class="p-2">
                                        <div class="row">
                                            <div class="col-4"><strong>MO Number:</strong></div>
                                            <div class="col-8"><span t-field="o.name"/></div>
                                        </div>
                                        <div class="row mt-1">
                                            <div class="col-4"><strong>Product:</strong></div>
                                            <div class="col-8">
                                                <span t-field="o.product_id.name"/>
                                                <br/>
                                                <small t-field="o.product_id.default_code"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 p-0">
                                    <div class="p-2">
                                        <div class="row">
                                            <div class="col-4"><strong>Lot Number:</strong></div>
                                            <div class="col-8" style="font-weight: bold;"><span t-out="main_lot.name if main_lot else 'N/A'"/></div>
                                        </div>
                                        <div class="row mt-1">
                                            <div class="col-4"><strong>Expiry Date:</strong></div>
                                            <div class="col-8" style="font-weight: bold;">
                                                <span t-out="main_lot.expiration_date if main_lot else 'N/A'" t-options='{"widget": "date"}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 3. Pre-Start Inspections -->
                            <div class="row m-0" style="background-color: #e9ecef; border-bottom: 1px solid #000;">
                                <div class="col-12 p-2">
                                    <strong style="font-size: 14px;">1. PRE-START INSPECTIONS</strong>
                                    <br/>
                                    <small><i>Perform inspection before starting the line. Initial and date to confirm compliance.</i></small>
                                </div>
                            </div>
                            <table class="table table-bordered mb-0" style="font-size: 11px;">
                                <thead>
                                    <tr style="background-color: #f8f9fa;">
                                        <th style="width: 50%; vertical-align: middle;">Inspection Item</th>
                                        <th class="text-center" style="width: 15%;">Initial / Date</th>
                                        <th class="text-center" style="width: 35%;">Comments (Write comment or N/A)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Food contact surfaces and equipment have been cleaned &amp; sanitised</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>All glass or brittle plastic materials are in good condition, no damages</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>Machinery present and functioning: with no loose nuts, bolts, screws, etc.</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>QCP-4: Magnets Checked – clean, in good condition, installed correctly.</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>QCP-3: Sieve Screen Check – top of tank - screen intact with no holes or damage, installed correctly. <br/><strong>Record Screen size: _____________</strong></td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>CCP-1: Sieve Check – discharge sifter – bottom of tank <br/>2 mm sieve, mesh intact with no holes or damage, Installed correctly with no visible bypass around seals. <br/><strong>Record Screen size: _____________</strong></td>
                                        <td/>
                                        <td/>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- 4. End of MO Inspections -->
                            <div class="row m-0" style="background-color: #e9ecef; border-top: 2px solid #000; border-bottom: 1px solid #000;">
                                <div class="col-12 p-2">
                                    <strong style="font-size: 14px;">2. END OF MO INSPECTIONS</strong>
                                    <br/>
                                    <small><i>Perform inspection at the end of production.</i></small>
                                </div>
                            </div>
                            <table class="table table-bordered mb-0" style="font-size: 11px;">
                                <thead>
                                    <tr style="background-color: #f8f9fa;">
                                        <th style="width: 50%; vertical-align: middle;">Inspection Item</th>
                                        <th class="text-center" style="width: 15%;">Initial / Date</th>
                                        <th class="text-center" style="width: 35%;">Comments (Write comment or N/A)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>QCP4: Magnets Checked – clean, in good condition, Check magnet for foreign objects.<br/>Corrective action: If foreign objecet found, <strong>notify supervisor</strong> immediately.</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>QCP 3: Sieve Screen Check – top of tank - clean with no foreign objects, no lose metal, nuts, bolts, screws. Record screen size:____________</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>CCP-1: Sieve Check – discharge sifter – bottom of tank <br/>2 mm sieve, mesh intact with no holes or damage. check sieve for foreign objects. <br/><strong>Record Screen size: ____________</strong><br/>Corrective actions: If seive mesh is damaged or torn, notify supervisor immediately. <strong>Stop production</strong> and place batch <strong>on hold</strong></td>
                                        <td/>
                                        <td/>
                                    </tr>
                                    <tr>
                                        <td>All tools and equipment have been cleaned and stored correctly</td>
                                        <td/>
                                        <td/>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- 5. Verification -->
                            <div class="row m-0" style="background-color: #f0f0f0; border-top: 2px solid #000; border-bottom: 1px solid #000;">
                                <div class="col-12 p-1 pl-2"><strong>VERIFICATION &amp; APPROVAL</strong></div>
                            </div>
                            <div class="row m-0 p-3">
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">OPERATOR NAME (PRINT)</div>
                                </div>
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">SIGNATURE</div>
                                </div>
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">DATE</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>