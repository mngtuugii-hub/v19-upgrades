<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_qfm_084" model="ir.actions.report">
        <field name="name">QFM-084 - Filling: Inprogress Checks</field>
        <field name="model">mrp.production</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tug_mrp_mods.report_qfm_084_template</field>
        <field name="report_file">tug_mrp_mods.report_qfm_084_template</field>
        <field name="paperformat_id" ref="paperformat_portrait_label_60dpi"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_qfm_084_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="main_lot" t-value="o.lot_producing_ids[0] if o.lot_producing_ids else False"/>

                <t t-call="web.internal_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px; color: #000;">
                        <div style="border: 2px solid #000;">
                            
                            <!-- Header -->
                            <div class="row m-0" style="border-bottom: 2px solid #000;">
                                <div class="col-3 p-2 d-flex align-items-center justify-content-center" style="border-right: 1px solid #000;">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 50px; max-width: 100%;"/>
                                    <span t-else="" t-field="o.company_id.name" style="font-weight: bold; font-size: 14px;"/>
                                </div>
                                <div class="col-6 p-2 text-center d-flex flex-column justify-content-center" style="border-right: 1px solid #000;">
                                    <h4 style="margin: 0; font-weight: 900; text-transform: uppercase;">Filling: In-Process Checks</h4>
                                </div>
                                <div class="col-3 p-1" style="font-size: 10px;">
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Doc No:</strong></div>
                                        <div class="col-8">QFM-084</div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Rev:</strong></div>
                                        <div class="col-8">1.0</div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4 text-right"><strong>Page:</strong></div>
                                        <div class="col-8"><span class="page"/> of <span class="topage"/></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Order Details -->
                            <div class="row m-0" style="background-color: #f0f0f0; border-bottom: 1px solid #000;">
                                <div class="col-12 p-1 pl-2"><strong>ORDER DETAILS</strong></div>
                            </div>
                            <div class="row m-0" style="border-bottom: 2px solid #000;">
                                <div class="col-6 p-2" style="border-right: 1px solid #000;">
                                    <strong>MO:</strong> <span t-field="o.name"/><br/>
                                    <strong>Product:</strong> <span t-field="o.product_id.name"/>
                                </div>
                                <div class="col-6 p-2">
                                    <strong>Lot:</strong> <span t-out="main_lot.name if main_lot else 'N/A'" style="font-weight:bold;"/><br/>
                                    <strong>Expiry:</strong> <span t-out="main_lot.expiration_date if main_lot else 'N/A'" t-options='{"widget": "date"}' style="font-weight:bold;"/>
                                </div>
                            </div>

                            <!-- Checks Matrix -->
                            <div class="row m-0" style="background-color: #e9ecef; border-bottom: 1px solid #000;">
                                <div class="col-12 p-2">
                                    <strong style="font-size: 14px;">IN-PROCESS CHECKS</strong>
                                </div>
                            </div>
                            
                            <table class="table table-bordered mb-0" style="font-size: 10px; text-align:center;">
                                <thead>
                                    <tr style="background-color: #f8f9fa;">
                                        <th style="width: 30%; text-align:right; vertical-align:middle;">TIME:</th>
                                        <th style="width: 17.5%;">__ : __</th>
                                        <th style="width: 17.5%;">__ : __</th>
                                        <th style="width: 17.5%;">__ : __</th>
                                        <th style="width: 17.5%;">__ : __</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="text-align:right;"><strong>Bulk Blend Labelled Correctly</strong><br/>(Item Code, Batch, BBD)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right; vertical-align:middle;" rowspan="6">
                                            <strong>Fill Weight Checks</strong><br/>
                                            <i>Record 12 packs per check</i><br/><br/>
                                            Target: ____<br/>Min: ____<br/>Max: ____
                                        </td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr><td/><td/><td/><td/></tr>
                                    <tr><td/><td/><td/><td/></tr>
                                    <tr><td/><td/><td/><td/></tr>
                                    <tr><td/><td/><td/><td/></tr>
                                    <tr><td/><td/><td/><td/></tr>
                                    <tr>
                                        <td style="text-align:right;">Unit Item Code Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Unit Batch &amp; BBD Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Inner Item Code Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Inner Batch &amp; BBD Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Qty per Inner</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Shipper Item Code Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Shipper Batch &amp; BBD Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Qty per Shipper</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;">Pallet Configuration Correct (Y/N)</td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>Checked By (Initials)</strong></td>
                                        <td/><td/><td/><td/>
                                    </tr>
                                </tbody>
                            </table>
                            
                            <!-- Footer -->
                             <div class="row m-0" style="background-color: #f0f0f0; border-top: 2px solid #000; border-bottom: 1px solid #000;">
                                <div class="col-12 p-1 pl-2"><strong>FINAL APPROVAL</strong></div>
                            </div>
                            <div class="row m-0 p-3">
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">OPERATOR NAME (PRINT)</div>
                                </div>
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">SIGNATURE</div>
                                </div>
                                <div class="col-4">
                                    <div style="border-bottom: 1px solid #000; height: 30px; width: 90%;"></div>
                                    <div style="font-size: 10px; margin-top: 2px;">DATE</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>