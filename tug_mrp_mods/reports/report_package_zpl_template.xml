<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mrp_package_zpl_template">
        <t t-foreach="docs" t-as="o">
            <!-- Filter for Done moves and find allocated packages -->
            <t t-set="finished_moves" t-value="o.move_finished_ids.filtered(lambda m: m.state == 'done')"/>
            <t t-set="all_lines" t-value="finished_moves.mapped('move_line_ids')"/>
            <!-- Get unique packages -->
            <t t-set="packages" t-value="all_lines.mapped('result_package_id')"/>
            
            <t t-foreach="packages" t-as="pkg">
                <t t-set="package" t-value="pkg"/>
                <t t-set="pkg_lines" t-value="all_lines.filtered(lambda l: l.result_package_id == pkg)"/>
                <!-- We take the first line to represent product/lot info -->
                <t t-set="products" t-value="pkg_lines[0]"/>
                
