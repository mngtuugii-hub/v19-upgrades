<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mrp_package_zpl_template">
        <t t-foreach="docs" t-as="o">
            
            <t t-if="o._name == 'mrp.production'">
                <!-- Filter for Done moves and find allocated packages -->
                <t t-set="finished_moves" t-value="o.move_finished_ids.filtered(lambda m: m.state == 'done')"/>
                <t t-set="all_lines" t-value="finished_moves.mapped('move_line_ids')"/>
                <t t-set="packages" t-value="all_lines.mapped('result_package_id')"/>
                <!-- Use lot producing ids for the MO -->
                <t t-set="main_lot" t-value="o.lot_producing_ids[0] if o.lot_producing_ids else False"/>
            </t>
            <t t-if="o._name == 'stock.picking'">
                <!-- Use all move lines in the picking -->
                <t t-set="all_lines" t-value="o.move_line_ids"/>
                <!-- Get packages (result_package_id is the destination pack) -->
                <t t-set="packages" t-value="all_lines.mapped('result_package_id')"/>
            </t>
            
            <t t-foreach="packages" t-as="pkg">
                <t t-set="package" t-value="pkg"/>
                <t t-set="pkg_lines" t-value="all_lines.filtered(lambda l: l.result_package_id == pkg)"/>
                <!-- We take the first line to represent product/lot info -->
                <t t-set="products" t-value="pkg_lines[0]"/>
                
                <!-- Fallback to line lot if not an MO -->
                <t t-if="o._name != 'mrp.production'">
                    <t t-set="main_lot" t-value="products.lot_id"/>
                </t>
                
^XA
^CI28
^PW812
^LL1218
^LS0

^FX -- Section 1: Header --
^CF0,70,70
^FO30,30^FD<t t-if="package.company_id"><t t-esc="package.company_id.name[:3].upper()"/> / </t><t t-if="package.location_id and package.location_id.location_id"><t t-esc="package.location_id.location_id.name"/> / </t><t t-if="package.location_id"><t t-esc="package.location_id.name"/></t>^FS
^FO0,115^GB812,0,3^FS

^FX -- Section 2: SSCC &amp; Item Description --
^CF0,35,35
^FO40,125^FDSSCC^FS
^CF0,60,60
<t t-if="package.name">
^FO150,165^FD<t t-esc="package.name"/>^FS
</t>
^CF0,35,35
<t t-if="products.product_id.name">
^FO40,235^FD<t t-esc="products.product_id.name[:40]"/>^FS
</t>
^FO0,285^GB812,0,3^FS

^FX -- Section 3: Item Details Table --
^CF0,25,25
^FO40,300^FDITEM No (Barcode)^FS
^FO500,300^FDQUANTITY (<t t-out="products.product_id.uom_id.name"/>)^FS

^CF0,50,50
<!-- Use Barcode if available, otherwise Code -->
<t t-if="products.product_id.barcode">
^FO40,330^FD<t t-esc="products.product_id.barcode"/>^FS
</t>
<t t-elif="products.product_id.default_code">
^FO40,330^FD<t t-esc="products.product_id.default_code"/>^FS
</t>

^CF0,75,75
<t t-if="products.quantity">
^FO500,330^FD<t t-esc="int(products.quantity)"/>^FS
</t>

^FX -- Section 4: Use By and Batch --
^CF0,25,25
^FO40,420^FDUSE BY (dd.mm.yyyy)^FS
^FO320,420^FDBATCH^FS

^CF0,50,50
<t t-if="main_lot and main_lot.expiration_date">
^FO40,450^FD<t t-esc="main_lot.expiration_date" t-options='{"widget": "date"}'/>^FS
</t>
<t t-if="main_lot and main_lot.name">
^FO320,450^FD<t t-esc="main_lot.name"/>^FS
</t>
^FO0,515^GB812,0,3^FS

^FX -- Section 5: Item Information Barcode (Top Barcode) --
^BY3,3,270
<t t-if="products.product_id.barcode">
    <t t-set="gtin" t-value="products.product_id.barcode"/>
    <t t-set="qty" t-value="int(products.quantity)"/>
    <t t-set="exp_str" t-value="''"/>
    <t t-if="main_lot and main_lot.expiration_date">
        <t t-set="exp_str" t-value="main_lot.expiration_date.strftime('%y%m%d')"/>
    </t>
    <t t-set="batch" t-value="main_lot.name if main_lot else ''"/>

<!-- GS1-128 Barcode Construction -->
^FO40,540^BCN,270,N,N,N,A
^FD&gt;;&gt;802<t t-esc="gtin"/>37<t t-esc="qty"/>&gt;817<t t-esc="exp_str"/>10<t t-esc="batch"/>^FS

<!-- Human Readable Text -->
^CF0,25,25
^FO40,820^FD(02)<t t-esc="gtin"/>(37)<t t-esc="qty"/>(17)<t t-esc="exp_str"/>(10)<t t-esc="batch"/>^FS
</t>

^FX -- Section 6: SSCC Barcode (Bottom Barcode) --
^BY4,3,270
<t t-if="package.name">
^FO80,870^BCN,270,N,N,N,A
^FD&gt;;&gt;800<t t-esc="package.name"/>^FS
^CF0,30,30
^FO150,1150^FD(00) <t t-esc="package.name"/>^FS
</t>

^XZ
            </t>
        </t>
    </template>
</odoo>