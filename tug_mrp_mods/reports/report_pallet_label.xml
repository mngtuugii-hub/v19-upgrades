<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_mo_product_label" model="ir.actions.report">
        <field name="name">Pallet Label (A4 Landscape)</field>
        <field name="model">mrp.production</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tug_mrp_mods.report_mo_product_label_template</field>
        <field name="report_file">tug_mrp_mods.report_mo_product_label_template</field>
        <field name="print_report_name">'Pallet Label - %s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_landscape_label"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_mo_product_label_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <t t-set="main_lot" t-value="o.lot_producing_ids[0] if o.lot_producing_ids else False"/>

                <div class="page" style="page-break-after: always; page-break-inside: avoid;">
                    <div style="border: 5px solid #000; padding: 15px; height: 188mm; box-sizing: border-box; display: flex; flex-direction: column; justify-content: space-between;">
                        
                        <div class="row" style="border-bottom: 3px solid #000; padding-bottom: 10px; margin-bottom: 10px; align-items: center;">
                            <div class="col-6">
                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 80px; max-width: 300px;"/>
                                <span t-else="" t-field="o.company_id.name" style="font-size: 32px; font-weight: bold;"/>
                            </div>
                            <div class="col-6 text-right">
                                <h1 style="font-size: 48px; font-weight: 900; margin: 0; text-transform: uppercase; letter-spacing: 2px;">FINISHED GOODS</h1>
                                <div style="font-size: 24px; font-weight: bold;">MO: <span t-field="o.name"/></div>
                            </div>
                        </div>

                        <div class="row align-items-center" style="flex-grow: 1; padding: 10px 0;">
                            <div class="col-3 text-center">
                                <img t-if="o.product_id.image_1920" t-att-src="image_data_uri(o.product_id.image_1920)" 
                                     style="max-height: 180px; max-width: 100%; object-fit: contain; border: 1px solid #ddd;"/>
                            </div>
                            <div class="col-9">
                                <div style="font-size: 20px; color: #666; text-transform: uppercase;">Product Description</div>
                                <div style="font-size: 56px; font-weight: 900; line-height: 1.1; margin-bottom: 5px;">
                                    <span t-field="o.product_id.name"/>
                                </div>
                                <div t-if="o.product_id.default_code" style="font-size: 32px; font-weight: bold;">
                                    <span style="color: #666;">REF:</span> <span t-field="o.product_id.default_code"/>
                                </div>
                            </div>
                        </div>

                        <div class="row" style="border-top: 3px solid #000; border-bottom: 3px solid #000; margin-bottom: 10px;">
                            <div class="col-7" style="border-right: 3px solid #000; padding: 15px;">
                                <div class="row mb-2 align-items-center">
                                    <div class="col-4 text-right" style="font-size: 28px; color: #444;">LOT / SERIAL:</div>
                                    <div class="col-8" style="font-size: 42px; font-weight: bold;">
                                        <span t-out="main_lot.name if main_lot else 'N/A'"/>
                                    </div>
                                </div>
                                <div class="row align-items-center">
                                    <div class="col-4 text-right" style="font-size: 28px; color: #444;">EXPIRY DATE:</div>
                                    <div class="col-8" style="font-size: 42px; font-weight: bold;">
                                        <span t-out="main_lot.expiration_date if main_lot else 'N/A'" t-options='{"widget": "date"}'/>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-5 text-center" style="padding: 15px;">
                                <div style="font-size: 28px; font-weight: bold; margin-bottom: 5px;">QUANTITY</div>
                                <div style="border: 4px solid #000; height: 100px; width: 80%; margin: 0 auto; position: relative;">
                                    <span t-field="o.product_uom_id.name" 
                                          style="position: absolute; bottom: 5px; right: 10px; font-size: 20px; color: #666; font-weight: bold;"/>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-end" style="padding-bottom: 5px;">
                            <div class="col-3 text-center" style="padding-bottom: 8px;">
                                <div style="font-size: 28px; font-weight: 900; text-transform: uppercase; margin-bottom: 5px;">PALLET #</div>
                                <div style="border: 4px solid #000; height: 100px; width: 80%; margin: 0 auto; background-color: #f8f9fa;"></div>
                            </div>

                            <div class="col-6 text-center">
                                <div style="font-size: 14px; margin-top: 5px;">MO Scan</div>
                                <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.name.replace('/', '%2F'), 600, 100)" style="width:100%;height:100px;"/>
                                <div style="font-size: 24px; font-weight: bold;">
                                    <span t-field="o.name"/>
                                </div>
                            </div>

                            <div class="col-3 text-center">
                                <div t-if="o.product_id.barcode">
                                    <div style="font-size: 14px; margin-top: 5px;">Product Scan</div>
                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('EAN13', o.product_id.barcode, 600, 100)" style="width:100%;height:100px;max-width:300px;"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>