<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mrp_internal_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.internal_layout">
                    <div class="page" style="font-family: Helvetica, Arial, sans-serif; font-size: 14px;">
                        
                        <div class="row mb-4" style="border-bottom: 2px solid #333; padding-bottom: 10px;">
                            <div class="col-7">
                                <h1 class="mt-0" style="font-weight: 900; font-size: 28px;">
                                    <span t-field="o.name"/>
                                </h1>
                                <div class="mt-2">
                                    <strong>Source Sales Order: </strong> <span t-field="o.original_sale_order_id" class="me-3"/>
                                    <strong>Date Planned: </strong> <span t-field="o.date_start"/>
                                </div>
                            </div>
                            <div class="col-5 text-end">
                                <div style="display: inline-block;">
                                    <span t-field="o.name" t-options="{'widget': 'barcode', 'width': 600, 'height': 100, 'img_style': 'width:250px;height:50px'}"/>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6" style="padding-right: 20px;">
                                <h5 class="text-uppercase text-muted" style="font-size: 12px; letter-spacing: 1px;">Product Identification</h5>
                                <div style="font-size: 16px; font-weight: bold;">
                                    <span t-field="o.product_id.name"/>
                                </div>
                                <h5 class="text-uppercase text-muted" style="font-size: 12px; letter-spacing: 1px;">Code</h5>
                                <div style="font-size: 16px; font-weight: bold;">
                                    <span t-field="o.product_id.default_code"/>
                                </div>

                                <div class="mt-4 p-3" style="background-color: #f0f0f0; border-left: 5px solid #333;">
                                    <div style="font-size: 12px; font-weight: bold; color: #555;">TARGET QUANTITY</div>
                                    <div style="font-size: 32px; font-weight: 900;">
                                        <span t-field="o.product_qty"/> <span t-field="o.product_uom_id.name" style="font-size: 18px;"/>
                                    </div>
                                </div>
                            </div>

                            <div class="col-6" style="padding-left: 20px; border-left: 1px solid #ddd;">
                                <h5 class="text-uppercase text-muted" style="font-size: 12px; letter-spacing: 1px;">Traceability</h5>
                                
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Customer:</strong></div>
                                    <div class="col-8"><span t-field="o.sale_order_partner_id"/></div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-4"><strong>Cust Ref:</strong></div>
                                    <div class="col-8"><span t-field="o.sale_order_ref"/></div>
                                </div>

                                <t t-set="main_lot" t-value="o.lot_producing_ids[0] if o.lot_producing_ids else False"/>
                                <t t-if="main_lot">
                                    <div class="p-2" style="background-color: #fff3cd; border: 1px solid #ffeeba; color: #856404;">
                                        <div class="row">
                                            <div class="col-12">
                                                <strong style="font-size: 11px;">LOT / BATCH:</strong><br/>
                                                <span style="font-size: 24px; font-weight: bold;" t-out="main_lot.name"/>
                                            </div>
                                        </div>
                                        <t t-if="main_lot.expiration_date">
                                            <div class="row">
                                                <div class="col-12 mt-2">
                                                    <strong style="font-size: 11px;">EXPIRY DATE (BBD):</strong><br/>
                                                    <span style="font-size: 24px; font-weight: bold;" 
                                                            t-out="main_lot.expiration_date" 
                                                            t-options='{"widget": "date"}'/>
                                                </div>
                                            </div>
                                        </t>
                                        <div class="alert alert-warning mt-2 mb-0" role="alert">
                                            <strong>⚠ Check Packing Specification from Customer for detailed formats!</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="row mt-4 mb-4">
                            <div class="col-12">
                                <div class="p-3" style="border: 1px solid #ccc;">
                                    <div class="row">
                                        <div class="col-6">
                                            <strong>Sample Qty (<span t-field="o.product_uom_id.name"/>):</strong>
                                            <div style="border-bottom: 2px solid #333; margin-top: 45px;"></div>
                                        </div>
                                        <div class="col-6">
                                            <strong>Actual Produced Qty (<span t-field="o.product_uom_id.name"/>):</strong>
                                            <div style="border-bottom: 2px solid #333; margin-top: 45px;"></div>
                                        </div>
                                    </div>
                                </div>

                                <t t-if="o.internal_production_note">
                                    <div class="alert alert-warning mt-2 mb-0" role="alert">
                                        <strong>⚠ Specific Instructions:</strong> <span t-field="o.internal_production_note"/>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <t t-if="o.workorder_ids">
                             <div class="row mt-4">
                                <div class="col-12">
                                    <h5 style="border-bottom: 2px solid #eee; padding-bottom: 5px; margin-bottom: 10px;">Operations</h5>
                                    <table class="table table-sm table-bordered" style="font-size: 13px;">
                                        <thead style="background-color: #eee;">
                                            <tr>
                                                <th style="width: 30%;">Operation</th>
                                                <th style="width: 25%;">Work Center</th>
                                                <th style="width: 45%;">Work Center Notes</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.workorder_ids" t-as="wo">
                                                <td style="vertical-align: top; font-weight: bold;"><span t-field="wo.name"/></td>
                                                <td style="vertical-align: top;"><span t-field="wo.workcenter_id.name"/></td>
                                                <td style="vertical-align: top;">
                                                    <span t-field="wo.workcenter_id.note"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <table class="table table-sm table-bordered mt-4" style="font-size: 13px;">
                            <thead style="background-color: #eee;">
                                <tr>
                                    <th style="width: 25%;">Component</th>
                                    <th style="width: 15%; font-weight: bold;">Pick From</th>
                                    <th class="text-end" style="width: 15%;">Required</th>
                                    <th class="text-end" style="width: 20%;">Consumed (Actual)</th>
                                    <th style="width: 15%;">Scrapped</th>
                                    <th class="text-end" style="width: 10%;">Returned</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.move_raw_ids" t-as="line">
                                    <td style="padding-top: 8px; padding-bottom: 8px;">
                                        <span style="font-weight: bold;" t-field="line.product_id.default_code"/> 
                                        <span t-field="line.product_id.name"/>
                                    </td>
                                    
                                    <td style="vertical-align: middle;">
                                        <t t-if="line.move_line_ids">
                                            <t t-foreach="line.move_line_ids" t-as="ml">
                                                <div style="margin-bottom: 2px;">
                                                    <t t-if="ml.package_id">
                                                        <span style="font-weight: bold;" t-field="ml.package_id.name"/>
                                                        <br/>
                                                        <span style="font-weight: bold;" t-field="ml.location_id.display_name"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="text-muted" t-field="ml.location_id.display_name"/>
                                                    </t>
                                                </div>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted" t-field="line.location_id.display_name"/>
                                        </t>
                                    </td>

                                    <td class="text-end" style="vertical-align: middle;">
                                        <span t-field="line.product_uom_qty"/> <span t-field="line.product_uom.name"/>
                                    </td>
                                    
                                    <td class="text-end" style="vertical-align: middle;">
                                        <t t-if="o.state=='done'">
                                            <span t-esc="sum(line.move_line_ids.mapped('quantity'))" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>
                                            <span t-field="line.product_uom.name"/>
                                        </t>
                                    </td>
                                    
                                    <td style="vertical-align: middle;">
                                        <t t-set="lots" t-value="line.move_line_ids.mapped('lot_id.name')"/>
                                        <span t-esc="', '.join(lots)"/>
                                    </td>

                                    <td class="text-end" style="vertical-align: middle;">
                                         <t t-set="scrapped_qty" t-value="sum(o.scrap_ids.filtered(lambda s: s.product_id == line.product_id).mapped('scrap_qty'))"/>
                                         <span t-if="scrapped_qty &gt; 0" t-esc="scrapped_qty" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>
                                    </td>
                                </tr>

                                <tr style="font-weight: bold; background-color: #f8f9fa; border-top: 2px solid #333;">
                                    <td colspan="2" class="text-end">Total:</td>
                                    <td class="text-end">
                                        <span t-esc="sum(o.move_raw_ids.mapped('product_uom_qty'))" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>
                                    </td>
                                    <td colspan="3"></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-5" style="page-break-inside: avoid;">
                            <div class="col-4">
                                <strong>Operator Name:</strong>
                                <div style="border-bottom: 1px solid black; margin-top: 40px; width: 90%;"/>
                            </div>
                            <div class="col-4">
                                <strong>Signature:</strong>
                                <div style="border-bottom: 1px solid black; margin-top: 40px; width: 90%;"/>
                            </div>
                            <div class="col-4">
                                <strong>Date:</strong>
                                <div style="border-bottom: 1px solid black; margin-top: 40px; width: 90%;"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>