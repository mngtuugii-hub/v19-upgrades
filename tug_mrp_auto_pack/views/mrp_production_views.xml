<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view_inherit_packages" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.packages</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_mrp_packages" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-gift" 
                        invisible="package_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="package_count"/>
                        </span>
                        <span class="o_stat_text">Packages</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>