<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_mrp_bom_report_professional" inherit_id="mrp.report_mrp_bom">
        <xpath expr="/t[@t-name='mrp.report_mrp_bom']" position="replace" mode="inner">
            <div class="o_mrp_bom_report_page container py-4 px-2 bg-view">
                <div t-if="data.get('lines')">
                    
                    <div class="row border-bottom border-dark pb-3 mb-4 align-items-center">
                        <div class="col-2">
                            <img t-if="env.company.logo" t-att-src="image_data_uri(env.company.logo)" alt="Company Logo" style="max-height: 65px; max-width: 100%; object-fit: contain;"/>
                        </div>
                        
                        <div class="col-6">
                            <h3 class="text-uppercase fw-bold text-dark mb-0">Bill of Materials Approval</h3>
                            <h5 class="text-muted mt-1">Production Specification Document</h5>
                        </div>
                        
                        <div class="col-4 text-end text-muted small">
                            <div><strong>Date Generated:</strong> <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%B %d, %Y')"/></div>
                            <div t-if="data.get('bom_code')"><strong>BoM reference:</strong> <t t-esc="data.get('version')"/></div>
                        </div>
                    </div>
                    
                    <div class="card mb-4 border-dark shadow-sm">
                        <div class="card-header bg-light border-dark py-2">
                            <h5 class="mb-0 fw-bold">Target Product Specification</h5>
                        </div>
                        <div class="card-body py-3">
                            <div class="row">
                                <div class="col-6">
                                    <strong class="text-muted small text-uppercase">Product Name</strong>
                                    <h4 class="mb-1 text-dark" t-esc="data.get('name')"/>
                                </div>
                                <div class="col-3">
                                    <strong class="text-muted small text-uppercase">Formula Version</strong>
                                    <p class="mb-0 fs-5" t-esc="data.get('bom_code') or 'Base'"/>
                                </div>
                                <div class="col-3 text-end">
                                    <strong class="text-muted small text-uppercase">Base Quantity</strong>
                                    <h4 class="mb-0 text-dark">
                                        <t t-esc="data.get('quantity')" t-options="{'widget': 'float', 'precision': 3}"/>
                                        <span class="fs-6 text-muted" groups="uom.group_uom" t-esc="data.get('uom_name')"/>
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <h5 class="fw-bold mb-3 text-uppercase" style="letter-spacing: 0.05em; font-size: 0.9rem;">Approved Material List</h5>
                    <table class="o_mrp_bom_expandable table table-sm table-bordered align-middle border-dark">
                        <thead class="table-light text-uppercase" style="font-size: 0.8rem;">
                            <tr>
                                <th name="th_mrp_bom_h" class="text-start py-2">Component / Material</th>
                                <th class="text-end py-2" style="width: 15%;">Required Qty</th>
                                <th class="text-start py-2" groups="uom.group_uom" style="width: 15%;">Unit</th>
                                
                                <th class="text-center py-2" style="width: 25%;">Marks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data.get('lines', [])" t-as="l">
                                <tr t-if="l.get('type') != 'operation'">
                                    <td class="text-start py-2">
                                        <span t-if="l.get('level')" t-out="'>' * l.get('level')"/>
                                        <span t-esc="l.get('name')"/>
                                    </td>
                                    <td class="text-end py-2">
                                        <span t-esc="l.get('quantity')" t-options="{'widget': 'float', 'precision': 3}"/>
                                    </td>
                                    <td class="text-start py-2" groups="uom.group_uom">
                                        <span t-esc="l.get('uom_name') or l.get('uom')"/>
                                    </td>
                                    
                                    <td class="text-center py-2"></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    
                    <div class="mt-5 pt-4" style="page-break-inside: avoid;">
                        <div class="bg-light p-4 border border-dark rounded">
                            <h4 class="mb-3 text-uppercase fw-bold border-bottom border-dark pb-2">Customer Quality Assurance Approval</h4>
                            
                            <p class="text-muted small mb-4 text-justify">
                                <strong>Authorization Statement:</strong> By signing below, the authorized representative confirms that the product specifications, material compositions, and quantities detailed in this Bill of Materials meet the agreed-upon quality and manufacturing standards. Production is hereby authorized to proceed utilizing strictly the components and parameters defined above.
                            </p>
                            
                            <div class="row mt-5">
                                <div class="col-4 mb-4">
                                    <div class="border-bottom border-dark" style="width: 90%; height: 2rem;"></div>
                                    <strong class="d-block mt-2 small text-uppercase">Authorized Signature</strong>
                                </div>
                                <div class="col-3 mb-4">
                                    <div class="border-bottom border-dark" style="width: 90%; height: 2rem;"></div>
                                    <strong class="d-block mt-2 small text-uppercase">Date of Approval</strong>
                                </div>
                                <div class="col-4">
                                    <div class="border-bottom border-dark" style="width: 90%; height: 2rem;"></div>
                                    <strong class="d-block mt-2 small text-uppercase">Printed Name</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                
                <div t-else="" class="d-flex align-items-center justify-content-center h-50">
                    <div class="text-center border p-5 bg-light rounded text-muted">
                        <i class="fa fa-folder-open-o fa-3x mb-3"></i>
                        <h4>No structural data available for this document.</h4>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>