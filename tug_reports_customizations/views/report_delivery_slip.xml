<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_stock_report_delivery_slip" inherit_id="stock.report_delivery_document">
        
        <xpath expr="//table[@name='stock_move_line_table']" position="replace">
            
            <table class="table table-sm mt-4" t-if="o.move_line_ids and o.state=='done'" name="custom_stock_move_line_table">
                <t t-set="has_serial_number" t-value="o.move_line_ids.filtered(lambda ml: ml.lot_id or ml.lot_name)"/>
                
                <thead>
                    <tr>
                        <th name="th_product"><strong>Product</strong></th>
                        
                        <th name="th_serial_number" class="text-center" t-if="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                            <strong>Lot</strong>
                            <strong groups="product_expiry.group_expiry_date_on_delivery_slip"> (BBD)</strong>
                        </th>
                        
                        <th class="text-end"><strong>Quantity Delivered</strong></th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="o.move_line_ids.sorted(lambda ml: (ml.product_id.default_code or '', ml.quantity))" t-as="ml">
                        <td>
                            <div class="fw-bold text-dark mb-1">
                                <span t-field="ml.product_id.default_code"/>
                            </div>
                            <div class="text-wrap">
                                <span t-field="ml.product_id.name"/>
                            </div>
                            <div t-if="ml.product_id.description_picking" class="text-muted small mt-1">
                                <i class="fa fa-info-circle me-1"/>
                                <span t-field="ml.product_id.description_picking"/>
                            </div>
                        </td>
                        
                        <td class="text-center align-middle" t-if="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                            <t t-if="ml.lot_id or ml.lot_name">
                                <t t-set="alert_date_reached" t-value="ml.lot_id.alert_date and ml.lot_id.alert_date &lt;= datetime.datetime.now()"/>
                                
                                <div t-att-class="'fw-bold mb-1 text-danger' if alert_date_reached else 'fw-bold mb-1'" style="font-family: monospace; font-size: 1.25em;">
                                    <span t-if="ml.lot_id" t-field="ml.lot_id.name"/>
                                    <span t-elif="ml.lot_name" t-esc="ml.lot_name"/>
                                </div>
                                
                                <div t-if="ml.lot_id.expiration_date" groups="product_expiry.group_expiry_date_on_delivery_slip" t-att-class="'small text-danger' if alert_date_reached else 'text-muted small'">
                                    <i class="fa fa-calendar-o me-1"/> 
                                    <span t-field="ml.lot_id.expiration_date" t-options="{'widget': 'date'}"/>
                                </div>
                            </t>
                            <span t-else="" class="text-muted">-</span>
                        </td>
                        
                        <td class="text-end align-middle">
                            <span t-field="ml.quantity"/>
                            <span t-field="ml.product_uom_id" groups="uom.group_uom"/>
                        </td>
                    </tr>
                </tbody>
            </table>

        </xpath>
    </template>
</odoo>